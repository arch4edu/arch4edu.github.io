---
import Base from '../layouts/Base.astro';
---

<Base title="Introduction - arch4edu">
  <div class="intro-page">
    <section class="intro-hero">
      <div class="intro-hero-brand">
        <img src="/logo.jpg" alt="arch4edu logo" class="intro-logo" />
        <img src="/arch4edu-text.svg" alt="arch4edu" class="intro-title-svg" />
      </div>
      <p class="intro-subtitle">Making your Arch Linux better for learning and researching.</p>
      <div class="intro-badges">
        <span class="badge-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          663 stars
        </span>
        <span class="badge-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/></svg>
          49 forks
        </span>
        <span class="badge-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          <a href="https://github.com/arch4edu/arch4edu" target="_blank" rel="noopener">Repository</a>
        </span>
      </div>
    </section>

    <section class="intro-section">
      <h3>What is arch4edu?</h3>
      <p>Arch4edu is a community repository for <strong>Arch Linux</strong> and <strong>Arch Linux ARM</strong> that strives to provide the latest versions of most software used by college students.</p>
      <p>Please visit the <a href="https://github.com/arch4edu/arch4edu/wiki" target="_blank" rel="noopener">wiki</a> for more information.</p>
    </section>

    <section class="intro-section">
      <h3>Usage</h3>
      <ul class="intro-list">
        <li><a href="https://github.com/arch4edu/arch4edu/wiki/Add-arch4edu-to-your-Archlinux" target="_blank" rel="noopener">Add arch4edu to your Arch Linux</a></li>
        <li><a href="https://github.com/arch4edu/arch4edu/wiki/Add-a-package-to-arch4edu" target="_blank" rel="noopener">Add a package to arch4edu</a></li>
      </ul>
    </section>

    <section class="intro-section">
      <h3>Related Projects</h3>
      <div class="project-card">
        <h4><a href="https://github.com/arch4edu/cactus" target="_blank" rel="noopener">arch4edu/cactus</a></h4>
        <p>Build system that automates package building and publishing for the arch4edu repository.</p>
      </div>
      <div class="project-card">
        <h4><a href="https://github.com/arch4edu/aur-auto-update" target="_blank" rel="noopener">arch4edu/aur-auto-update</a></h4>
        <p>Automatically updates packages on AUR when new versions are available.</p>
      </div>
    </section>

    <section class="intro-section">
      <h3>Community</h3>
      <div class="community-grid">
        <a href="https://arch4edu.org" target="_blank" rel="noopener" class="community-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          Homepage
        </a>
        <a href="https://twitter.com/arch4edu" target="_blank" rel="noopener" class="community-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/></svg>
          Twitter
        </a>
        <a href="https://t.me/arch4edu" target="_blank" rel="noopener" class="community-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.198 2.433a2.242 2.242 0 0 0-1.022.215l-8.609 3.33c-2.068.8-4.133 1.598-5.724 2.21a405.15 405.15 0 0 1-2.849 1.09c-.42.147-.99.332-1.473.901-.728.855.044 1.638.467 1.965.378.292.895.534 1.245.67l3.288 1.265c.3.897.6 1.794.9 2.69.233.476.676.867 1.211.867.396 0 .765-.157 1.047-.403l2.125-1.86 3.57 2.724c.193.148.405.26.63.336.225.076.46.116.701.116.75 0 1.387-.424 1.713-1.037.195-.368.299-.856.381-1.32l2.19-12.677c.137-.6.137-1.15-.102-1.628a1.803 1.803 0 0 0-1.688-.856z"/></svg>
          Telegram Channel
        </a>
        <a href="https://t.me/arch4edu_general" target="_blank" rel="noopener" class="community-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Telegram Group
        </a>
        <a href="https://matrix.to/#/#arch4edu-general:libera.chat" target="_blank" rel="noopener" class="community-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2"/><path d="M7 7h10v10"/><path d="M7 17L17 7"/></svg>
          Matrix
        </a>
        <a href="ircs://irc.libera.chat/#arch4edu-general" class="community-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
          IRC
        </a>
      </div>
    </section>
  </div>
</Base>

<style>
  .intro-page {
    max-width: 720px;
    margin: 0 auto;
  }

  .intro-hero {
    text-align: center;
    padding: 2.5rem 0 2rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .intro-hero-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .intro-logo {
    width: 64px;
    height: 64px;
    border-radius: 12px;
  }

  .intro-title-svg {
    height: 2.5rem;
    width: auto;
  }

  :global([data-theme="dark"]) .intro-title-svg {
    filter: brightness(0) invert(1);
  }

  .intro-subtitle {
    color: var(--text-secondary);
    font-size: 1rem;
    margin-bottom: 1.25rem;
  }

  .intro-badges {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .badge-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    padding: 0.3rem 0.6rem;
    border-radius: 4px;
  }

  .badge-item a {
    color: var(--accent);
  }

  .intro-section {
    margin-bottom: 2rem;
  }

  .intro-section h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--border);
  }

  .intro-section p {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 0.5rem;
  }

  .intro-list {
    list-style: none;
    padding: 0;
  }

  .intro-list li {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--bg-tertiary);
  }

  .intro-list li:last-child {
    border-bottom: none;
  }

  .intro-list li::before {
    content: "\2192";
    margin-right: 0.5rem;
    color: var(--accent);
  }

  .project-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    margin-bottom: 0.75rem;
    transition: border-color 0.15s;
  }

  .project-card:hover {
    border-color: var(--accent);
  }

  .project-card h4 {
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
  }

  .project-card p {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin: 0;
  }

  .community-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.6rem;
  }

  .community-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.8rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-secondary);
    font-size: 0.8rem;
    transition: border-color 0.15s, color 0.15s;
    text-decoration: none;
  }

  .community-link:hover {
    border-color: var(--accent);
    color: var(--accent);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .intro-hero {
      padding: 1.5rem 0 1.25rem;
    }

    .intro-logo {
      width: 60px;
    }

    .intro-title-svg {
      height: 1.8rem;
    }

    .community-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
