---
import Base from '../layouts/Base.astro';
---

<Base title="arch4edu - aarch64 Build Status">
  <div class="dashboard">
    <section class="summary" id="summary">
      <div class="summary-card summary-total">
        <span class="summary-number" id="total-count">-</span>
        <span class="summary-label">Total</span>
      </div>
      <div class="summary-card summary-ok">
        <span class="summary-number" id="ok-count">-</span>
        <span class="summary-label">Published</span>
      </div>
      <div class="summary-card summary-fail">
        <span class="summary-number" id="fail-count">-</span>
        <span class="summary-label">Failed</span>
      </div>
      <div class="summary-card summary-stale">
        <span class="summary-number" id="stale-count">-</span>
        <span class="summary-label">Stale</span>
      </div>
    </section>

    <section class="controls">
      <div class="search-box">
        <input type="text" id="search" placeholder="Search packages..." autocomplete="off" />
      </div>
      <div class="filters">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="PUBLISHED">Published</button>
        <button class="filter-btn" data-filter="FAILED">Failed</button>
        <button class="filter-btn" data-filter="STALE">Stale</button>
      </div>
      <div class="category-filters" id="category-filters">
        <!-- dynamically populated -->
      </div>
    </section>

    <section class="table-container">
      <div class="table-info">
        <span id="showing-count">Loading...</span>
        <span class="update-time" id="update-time"></span>
      </div>
      <div class="table-scroll">
        <table class="build-table" id="build-table">
          <thead>
            <tr>
              <th class="col-status">Status</th>
              <th class="col-package">Package</th>
              <th class="col-info">Info</th>
              <th class="col-time">Updated</th>
            </tr>
          </thead>
          <tbody id="table-body">
          </tbody>
        </table>
      </div>
      <div class="pagination" id="pagination"></div>
    </section>
  </div>
</Base>

<style>
  .dashboard {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .summary {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .summary-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .summary-number {
    font-size: 2rem;
    font-weight: 600;
    font-family: var(--font-display);
  }

  .summary-label {
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .summary-total .summary-number { color: var(--text-primary); }
  .summary-ok .summary-number { color: var(--status-ok); }
  .summary-fail .summary-number { color: var(--status-fail); }
  .summary-stale .summary-number { color: var(--status-stale); }

  .controls {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  .search-box {
    flex: 1;
    min-width: 200px;
  }

  .search-box input {
    width: 100%;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.6rem 1rem;
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    outline: none;
    transition: border-color 0.15s;
  }

  .search-box input:focus {
    border-color: var(--accent);
  }

  .search-box input::placeholder {
    color: var(--text-muted);
  }

  .filters, .category-filters {
    display: flex;
    gap: 0.5rem;
  }

  .filter-btn, .cat-btn {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.4rem 0.75rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.15s;
  }

  .filter-btn:hover, .cat-btn:hover {
    background: var(--bg-tertiary);
    color: var(--text-primary);
  }

  .filter-btn.active {
    background: var(--accent-dim);
    border-color: var(--accent);
    color: var(--accent);
  }

  .cat-btn.active {
    background: var(--bg-tertiary);
    border-color: var(--text-secondary);
    color: var(--text-primary);
  }

  .table-container {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .table-info {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .table-scroll {
    overflow-x: auto;
  }

  .build-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
  }

  .build-table th {
    background: var(--bg-tertiary);
    padding: 0.6rem 1rem;
    text-align: left;
    font-weight: 500;
    color: var(--text-secondary);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    position: sticky;
    top: 0;
    white-space: nowrap;
  }

  .build-table td {
    padding: 0.5rem 1rem;
    border-top: 1px solid var(--border);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .build-table tr:hover td {
    background: var(--bg-tertiary);
  }

  .col-status { width: 90px; }
  .col-info { max-width: 300px; }
  .col-time { width: 100px; }

  .badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .badge-published {
    background: var(--status-ok-bg);
    color: var(--status-ok);
    border: 1px solid var(--status-ok);
  }

  .badge-failed {
    background: var(--status-fail-bg);
    color: var(--status-fail);
    border: 1px solid var(--status-fail);
  }

  .badge-stale {
    background: var(--status-stale-bg);
    color: var(--status-stale);
    border: 1px solid var(--status-stale);
  }

  .badge-building {
    background: var(--status-building-bg);
    color: var(--status-building);
    border: 1px solid var(--status-building);
  }

  .pagination {
    padding: 0.75rem 1rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    align-items: center;
  }

  .pagination button {
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.3rem 0.6rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    cursor: pointer;
  }

  .pagination button:hover {
    color: var(--text-primary);
    border-color: var(--text-secondary);
  }

  .pagination button.active {
    background: var(--accent-dim);
    border-color: var(--accent);
    color: var(--accent);
  }

  .pagination button:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .page-info {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .summary {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    .controls {
      flex-direction: column;
      align-items: stretch;
      gap: 0.75rem;
    }

    .search-box { min-width: unset; }
    .search-box input { padding: 0.75rem 1rem; font-size: 1rem; }

    .filters, .category-filters {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: 2px;
    }

    .filters::-webkit-scrollbar, .category-filters::-webkit-scrollbar { display: none; }

    .filter-btn, .cat-btn {
      padding: 0.5rem 0.75rem;
      font-size: 0.8rem;
      flex-shrink: 0;
      min-height: 36px;
    }

    .table-info {
      flex-direction: column;
      gap: 0.25rem;
      align-items: flex-start;
      padding: 0.6rem 0.75rem;
    }

    .table-scroll {
      -webkit-overflow-scrolling: touch;
    }

    .build-table th, .build-table td { padding: 0.5rem 0.6rem; }
    .col-info { display: none; }

    .pagination {
      flex-wrap: wrap;
      padding: 0.6rem 0.5rem;
      gap: 0.35rem;
    }

    .pagination button { min-width: 32px; min-height: 32px; }
  }

  @media (max-width: 480px) {
    .summary { grid-template-columns: repeat(4, 1fr); gap: 0.5rem; }
    .summary-card { padding: 0.75rem 0.5rem; }
    .summary-number { font-size: 1.25rem; }
    .summary-label { font-size: 0.65rem; }
    .build-table { font-size: 0.75rem; }
    .badge { font-size: 0.6rem; padding: 0.1rem 0.35rem; }
  }
</style>

<script>
  const API_URL = 'https://api.arch4edu.org/status/builds.json';
  const ARCH_PREFIX = 'aarch64';
  const PAGE_SIZE = 100;

  let allPackages: any[] = [];
  let filtered: any[] = [];
  let currentPage = 1;
  let currentFilter = 'all';
  let currentSubCat = 'all';
  let searchTerm = '';

  async function init() {
    try {
      const res = await fetch(API_URL);
      const data = await res.json();
      // Filter only aarch64 packages
      allPackages = data.packages.filter((p: any) => p.category.startsWith(ARCH_PREFIX));
      updateSummary();
      buildCategoryButtons();
      applyFilters();
    } catch (e) {
      document.getElementById('showing-count')!.textContent = 'Failed to load data';
    }
  }

  function updateSummary() {
    const counts = { PUBLISHED: 0, FAILED: 0, STALE: 0, BUILDING: 0 };
    for (const p of allPackages) {
      if (p.status in counts) counts[p.status as keyof typeof counts]++;
    }
    document.getElementById('total-count')!.textContent = String(allPackages.length);
    document.getElementById('ok-count')!.textContent = String(counts.PUBLISHED);
    document.getElementById('fail-count')!.textContent = String(counts.FAILED);
    document.getElementById('stale-count')!.textContent = String(counts.STALE);

    const time = new Date(Date.now());
    document.getElementById('update-time')!.textContent = `aarch64 packages`;
  }

  function buildCategoryButtons() {
    const cats = new Set(allPackages.map((p: any) => p.category));
    const container = document.getElementById('category-filters')!;
    let html = '<button class="cat-btn active" data-cat="all">all</button>';
    for (const cat of [...cats].sort()) {
      const label = cat === ARCH_PREFIX ? ARCH_PREFIX : cat.replace(ARCH_PREFIX + '/', '');
      html += `<button class="cat-btn" data-cat="${cat}">${label}</button>`;
    }
    container.innerHTML = html;

    container.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.cat-btn') as HTMLElement | null;
      if (!btn) return;
      container.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentSubCat = btn.dataset.cat!;
      applyFilters();
    });
  }

  function applyFilters() {
    filtered = allPackages.filter(p => {
      if (currentFilter !== 'all' && p.status !== currentFilter) return false;
      if (currentSubCat !== 'all' && p.category !== currentSubCat) return false;
      if (searchTerm && !p.key.toLowerCase().includes(searchTerm) && !p.detail.toLowerCase().includes(searchTerm)) return false;
      return true;
    });
    currentPage = 1;
    render();
  }

  function render() {
    const start = (currentPage - 1) * PAGE_SIZE;
    const page = filtered.slice(start, start + PAGE_SIZE);
    const tbody = document.getElementById('table-body')!;

    tbody.innerHTML = page.map(p => `
      <tr>
        <td><span class="badge badge-${p.status.toLowerCase()}">${p.status}</span></td>
        <td><a href="/package?key=${encodeURIComponent(p.key)}">${p.pkgbase}</a></td>
        <td class="cell-info">${renderInfoCell(p)}</td>
        <td>${formatTime(p.timestamp)}</td>
      </tr>
    `).join('');

    document.getElementById('showing-count')!.textContent = `Showing ${start + 1}-${Math.min(start + PAGE_SIZE, filtered.length)} of ${filtered.length}`;
    renderPagination();
  }

  function renderPagination() {
    const totalPages = Math.ceil(filtered.length / PAGE_SIZE);
    const container = document.getElementById('pagination')!;
    if (totalPages <= 1) { container.innerHTML = ''; return; }
    let html = `<button ${currentPage === 1 ? 'disabled' : ''} data-page="${currentPage - 1}">&laquo;</button>`;
    const range = getPageRange(currentPage, totalPages);
    for (const p of range) {
      if (p === '...') html += `<span class="page-info">...</span>`;
      else html += `<button class="${p === currentPage ? 'active' : ''}" data-page="${p}">${p}</button>`;
    }
    html += `<button ${currentPage === totalPages ? 'disabled' : ''} data-page="${currentPage + 1}">&raquo;</button>`;
    container.innerHTML = html;
  }

  function getPageRange(current: number, total: number): (number | string)[] {
    if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
    const pages: (number | string)[] = [1];
    if (current > 3) pages.push('...');
    for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) pages.push(i);
    if (current < total - 2) pages.push('...');
    pages.push(total);
    return pages;
  }

  function formatTime(ts: number): string {
    if (!ts) return '';
    const diff = Math.floor(Date.now() / 1000) - ts;
    if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
    if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
    if (diff < 604800) return `${Math.floor(diff / 86400)}d ago`;
    return new Date(ts * 1000).toLocaleDateString();
  }

  function escapeHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function renderInfoCell(p: any): string {
    const status = (p.status || '').toUpperCase();
    switch (status) {
      case 'STALE':
        return escapeHtml(p.detail || 'Stale');
      case 'PUBLISHED':
      case 'BUILT':
        return p.workflow ? `<a href="${p.workflow_url}" target="_blank">${p.workflow}</a>` : '';
      case 'BUILDING':
      case 'FAILED':
        const label = escapeHtml(p.detail || status);
        return p.workflow_url ? `<a href="${p.workflow_url}" target="_blank">${label}</a>` : label;
      case 'SCHEDULED':
        return '';
      default:
        return escapeHtml(p.detail || '');
    }
  }

  document.getElementById('search')!.addEventListener('input', (e) => {
    searchTerm = (e.target as HTMLInputElement).value.toLowerCase().trim();
    applyFilters();
  });

  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentFilter = (btn as HTMLElement).dataset.filter!;
      applyFilters();
    });
  });

  document.getElementById('pagination')!.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button');
    if (!btn || btn.disabled) return;
    currentPage = Number(btn.dataset.page);
    render();
  });

  init();
</script>
