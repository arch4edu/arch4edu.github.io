---
export interface Props {
  title: string;
}

const { title } = Astro.props;
const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '/index.html';
const isAarch64 = pathname.startsWith('/aarch64');
const isIntro = pathname.startsWith('/intro');
const isApi = pathname.startsWith('/api');
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="description" content="arch4edu - Arch Linux Repository for Education. Build status dashboard." />
    <title>{title}</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#1793d1" />
    <link rel="preconnect" href="https://fonts.bunny.net" />
    <link href="https://fonts.bunny.net/css?family=ibm-plex-mono:400,500,600|fraunces:600,700" rel="stylesheet" />
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', t);
        var im = localStorage.getItem('icon_mode') === 'true';
        if (im) document.documentElement.setAttribute('data-icon-mode', 'true');
      })();
    </script>
  </head>
  <body>
    <div class="layout">
      <header class="site-header">
        <div class="header-brand">
          <img src="/logo.jpg" alt="arch4edu logo" class="header-logo" width="40" height="40" />
          <div class="header-text">
            <img src="/arch4edu-text.svg" alt="arch4edu" class="site-title-svg" />
            <p class="site-tagline">Arch Linux Repository for Education</p>
          </div>
        </div>
        <nav class="site-nav">
          <a href="/intro" class:list={["nav-link", { active: isIntro }]}>Introduction</a>
          <a href="/" class:list={["nav-link", { active: isHome }]}>Build Status</a>
          <a href="/api" class:list={["nav-link", { active: isApi }]}>API</a>
          <span class="nav-spacer"></span>
          <button class="theme-toggle" id="icon-mode-toggle" aria-label="Toggle icon mode" title="Toggle status icons">
            <svg class="icon-text-mode" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>
            <svg class="icon-emoji-mode" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
          </button>
          <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme" title="Toggle theme">
            <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
        </nav>
      </header>
      <main class="site-main">
        <slot />
      </main>
      <footer class="site-footer">
        <span>arch4edu &middot; powered by <a href="https://github.com/arch4edu/cactus">cactus</a></span>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --font-mono: 'IBM Plex Mono', monospace;
    --font-display: 'Fraunces', serif;

    --bg-primary: #ffffff;
    --bg-secondary: #f6f8fa;
    --bg-tertiary: #eaeef2;
    --border: #d0d7de;

    --text-primary: #1f2328;
    --text-secondary: #656d76;
    --text-muted: #8c959f;

    --accent: #1793d1;
    --accent-dim: #1793d122;

    --status-ok: #1a7f37;
    --status-ok-bg: #1a7f3715;
    --status-fail: #cf222e;
    --status-fail-bg: #cf222e15;
    --status-stale: #9a6700;
    --status-stale-bg: #9a670015;
    --status-building: #0969da;
    --status-building-bg: #0969da15;

    --safe-top: env(safe-area-inset-top, 0px);
    --safe-bottom: env(safe-area-inset-bottom, 0px);
    --safe-left: env(safe-area-inset-left, 0px);
    --safe-right: env(safe-area-inset-right, 0px);
  }

  [data-theme="dark"] {
    --bg-primary: #0d1117;
    --bg-secondary: #161b22;
    --bg-tertiary: #1c2128;
    --border: #30363d;

    --text-primary: #e6edf3;
    --text-secondary: #8b949e;
    --text-muted: #484f58;

    --accent: #1793d1;
    --accent-dim: #1793d133;

    --status-ok: #3fb950;
    --status-ok-bg: #3fb95015;
    --status-fail: #f85149;
    --status-fail-bg: #f8514915;
    --status-stale: #d29922;
    --status-stale-bg: #d2992215;
    --status-building: #79c0ff;
    --status-building-bg: #79c0ff15;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-size: 14px;
    -webkit-text-size-adjust: 100%;
  }

  body {
    font-family: var(--font-mono);
    background: var(--bg-primary);
    color: var(--text-primary);
    min-height: 100vh;
    min-height: 100dvh;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  .layout {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    min-height: 100dvh;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
    padding-top: var(--safe-top);
    padding-left: max(1.5rem, var(--safe-left));
    padding-right: max(1.5rem, var(--safe-right));
    padding-bottom: var(--safe-bottom);
  }

  .site-header {
    padding: 1.5rem 0 1rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .header-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .header-logo {
    border-radius: 8px;
    object-fit: cover;
  }

  .site-title-svg {
    height: 1.4rem;
    width: auto;
    display: block;
  }

  [data-theme="dark"] .site-title-svg {
    filter: brightness(0) invert(1);
  }

  .site-tagline {
    color: var(--text-secondary);
    font-size: 0.75rem;
    line-height: 1.3;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-spacer {
    flex: 1;
  }

  .nav-link {
    color: var(--text-secondary);
    font-size: 0.8rem;
    padding: 0.35rem 0.6rem;
    border-radius: 4px;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .nav-link:hover {
    background: var(--bg-tertiary);
    color: var(--text-primary);
    text-decoration: none;
  }

  .nav-link.active {
    background: var(--accent-dim);
    color: var(--accent);
  }

  .site-main {
    flex: 1;
    padding: 1.5rem 0;
  }

  .site-footer {
    padding: 1.25rem 0;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.75rem;
    text-align: center;
  }

  .site-footer a {
    color: var(--text-secondary);
  }

  .theme-toggle {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.35rem 0.5rem;
    color: var(--text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s;
  }

  .theme-toggle:hover {
    background: var(--bg-tertiary);
    color: var(--text-primary);
  }

  /* Light theme: show moon (click to go dark), hide sun */
  :root .icon-sun { display: none; }
  :root .icon-moon { display: block; }
  /* Dark theme: show sun (click to go light), hide moon */
  [data-theme="dark"] .icon-sun { display: block; }
  [data-theme="dark"] .icon-moon { display: none; }

  /* Icon mode toggle: default shows text icon (T), active shows emoji icon */
  .icon-text-mode { display: block; }
  .icon-emoji-mode { display: none; }
  [data-icon-mode="true"] .icon-text-mode { display: none; }
  [data-icon-mode="true"] .icon-emoji-mode { display: block; }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    html {
      font-size: 13px;
    }

    .layout {
      padding-left: max(1rem, var(--safe-left));
      padding-right: max(1rem, var(--safe-right));
    }

    .site-header {
      padding: 1rem 0 0.75rem;
      flex-direction: column;
      align-items: flex-start;
    }

    .header-logo {
      width: 32px;
      height: 32px;
    }

    .site-title-svg {
      height: 1.1rem;
    }

    .site-nav {
      width: 100%;
    }

    .site-main {
      padding: 1rem 0;
    }
  }
</style>

<script>
  const toggle = document.getElementById('theme-toggle')!;
  toggle.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });

  const iconToggle = document.getElementById('icon-mode-toggle')!;
  iconToggle.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-icon-mode') === 'true';
    const next = !current;
    if (next) {
      document.documentElement.setAttribute('data-icon-mode', 'true');
    } else {
      document.documentElement.removeAttribute('data-icon-mode');
    }
    localStorage.setItem('icon_mode', String(next));
    document.dispatchEvent(new CustomEvent('icon-mode-changed'));
  });
</script>
